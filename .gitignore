# IDE / editor
.vs/
.vscode/
.idea/
*.user
*.suo
*.sln.docstates
*.swp
*.swo
*~

# Node (only relevant if/when OpenSpec runs locally)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS clutter
.DS_Store
Thumbs.db
desktop.ini

# Local secrets / runtime config
.env
.env.local
*.local.json

# Certificates and private keys — must never enter version control
*.pfx
*.p12
*.pem
*.key
*.cer
*.crt

# ASP.NET local-environment overrides — may contain real credentials
appsettings.Local.json
appsettings.*.Local.json

# Ad-hoc secrets files
secrets.json

# .NET build outputs
/obj/
/bin/
src/**/obj/
src/**/bin/
tools/**/obj/
tools/**/bin/
tests/**/obj/
tests/**/bin/
*.user

# Test results and coverage
TestResults/
coverage*/
*.coverage

# CI artefact files — generated locally; do not commit (CI uploads them as artefacts)
traceability.md
traceability-local.md
licence-inventory.md

# Working / scratch notes (not part of the repo)
resume.txt
notes/

# Raw off-air WAV corpus — too large to commit AND contains real third-party
# callsigns (personal data); local only, never commit (NFR-021 / GDPR).
p10-decoder-ground-truth_items/

# UAT-01 raw off-air WAV corpus — local only; real third-party callsigns (NFR-021).
p12-ft8lib-port_UAT-01_items/

# p16 CAT control live capture samples (ALL-*.TXT, *.log) — operator artefacts,
# may contain real third-party callsigns; local only (NFR-021 / GDPR).
p16-cat-control_items/

# D001 PCM-SIC development corpus — real off-air WAVs and ALL.TXT logs containing
# real third-party callsigns; local only (NFR-021 / GDPR).
D001-pcm-sic_items/

# Daemon runtime output — generated files
ALL.TXT

# Native build artifacts — obj files and intermediate DLL (patched sources are committed)
# Exception: message.obj has been binary-patched (D-006, shim 20260015) and must be tracked
# so that DLL rebuilds use the corrected object.  All other obj files are untracked build
# intermediates regenerable from the patched sources in native/ft8_lib_build/patched/.
# Note: directory-level ignores block file-level negations, hence the wildcard form.
native/ft8_lib_build/obj/*
!native/ft8_lib_build/obj/message.obj
native/ft8_lib_build/linux_obj/
native/ft8_lib_build/*.obj
native/ft8_lib_build/*.exp
native/ft8_lib_build/*.lib
native/ft8_lib_build/libft8.dll
native/ft8_lib_build/libft8.so

# Scratch comparison binaries placed at repo root (not the committed platform binaries)
baseline_libft8.dll

# Serena MCP tool — logs and runtime artefacts (project config is committed)
daemon_log.txt

# Application log files (FR-022) — operator artefacts, not source
logs/

# Claude Code runtime lock file — local only, not source
.claude/scheduled_tasks.lock

# S6 corpus replay — raw ALL.TXT snapshots contain real third-party callsigns (NFR-021).
# Committed artifacts (report.md, summary.csv, *.png) are scrubbed by analyse_corpus.py.
qa/rr-study/results/corpus-*/raw/
qa/rr-study/results/corpus-*/run_manifest.json
